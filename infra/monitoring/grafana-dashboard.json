{
  "dashboard": {
    "id": null,
    "uid": "ruview-main",
    "title": "RuView — WiFi CSI 모니터링",
    "tags": ["ruview", "csi", "presence", "vitals"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 39,
    "version": 1,
    "time": { "from": "now-30m", "to": "now" },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    },
    "panels": [
      {
        "id": 1,
        "title": "재실 현황",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "collapsed": false
      },
      {
        "id": 2,
        "title": "현재 재실 인원",
        "type": "stat",
        "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(ruview_occupancy_persons)",
            "legendFormat": "재실 인원",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 3 },
                { "color": "red", "value": 6 }
              ]
            },
            "unit": "short",
            "mappings": [{ "type": "value", "options": { "0": { "text": "없음" } } }]
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
      },
      {
        "id": 3,
        "title": "재실 감지 여부",
        "type": "stat",
        "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "max(ruview_presence_detected)",
            "legendFormat": "재실",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "blue", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            },
            "mappings": [
              { "type": "value", "options": { "0": { "text": "비어있음" }, "1": { "text": "재실 중" } } }
            ]
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
      },
      {
        "id": 4,
        "title": "낙상 이벤트 (1시간)",
        "type": "stat",
        "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "increase(ruview_fall_events_total[1h])",
            "legendFormat": "낙상",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            },
            "unit": "short"
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
      },
      {
        "id": 5,
        "title": "온라인 노드",
        "type": "stat",
        "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "count(up{job=\"signal-adapter\"} == 1)",
            "legendFormat": "온라인",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "green", "value": 6 }
              ]
            },
            "unit": "short"
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
      },
      {
        "id": 6,
        "title": "CSI 처리 처리량 (pps)",
        "type": "stat",
        "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(ruview_csi_packets_received_total[1m]))",
            "legendFormat": "pps",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "green", "value": 50 }
              ]
            },
            "unit": "pps"
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
      },
      {
        "id": 7,
        "title": "WS 클라이언트",
        "type": "stat",
        "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "ruview_ws_clients_connected",
            "legendFormat": "클라이언트",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "blue", "value": 0 },
                { "color": "green", "value": 1 }
              ]
            },
            "unit": "short"
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
      },
      {
        "id": 10,
        "title": "생체신호 모니터링",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
        "collapsed": false
      },
      {
        "id": 11,
        "title": "심박수 (BPM)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "ruview_heart_rate_bpm",
            "legendFormat": "노드 {{ node_id }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
            "unit": "short",
            "min": 0,
            "max": 200,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 40 },
                { "color": "yellow", "value": 100 },
                { "color": "red", "value": 120 }
              ]
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "심박수" },
              "properties": [{ "id": "color", "value": { "fixedColor": "#f43f5e", "mode": "fixed" } }]
            }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },
      {
        "id": 12,
        "title": "호흡수 (RPM)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "ruview_breathing_rate_rpm",
            "legendFormat": "노드 {{ node_id }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
            "unit": "short",
            "min": 0,
            "max": 40,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 8 },
                { "color": "yellow", "value": 25 },
                { "color": "red", "value": 30 }
              ]
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "호흡수" },
              "properties": [{ "id": "color", "value": { "fixedColor": "#38bdf8", "mode": "fixed" } }]
            }
          ]
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },
      {
        "id": 20,
        "title": "ESP32 노드 상태",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
        "collapsed": false
      },
      {
        "id": 21,
        "title": "CSI 패킷 수신률 (노드별)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(ruview_csi_packets_received_total[1m])",
            "legendFormat": "{{ node_id }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 1.5, "fillOpacity": 5 },
            "unit": "pps"
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "last"] } }
      },
      {
        "id": 22,
        "title": "노드 RSSI 분포",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "ruview_rssi_dbm",
            "legendFormat": "{{ node_id }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": -90 },
                { "color": "yellow", "value": -75 },
                { "color": "green", "value": -50 }
              ]
            },
            "unit": "dBm",
            "min": -100,
            "max": -20
          }
        },
        "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
      },
      {
        "id": 30,
        "title": "서비스 성능",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
        "collapsed": false
      },
      {
        "id": 31,
        "title": "CSI 처리 지연 (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(ruview_csi_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(ruview_csi_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(ruview_csi_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": { "lineWidth": 2, "fillOpacity": 5 }
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },
      {
        "id": 32,
        "title": "API 요청률 (signal-adapter)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"signal-adapter\"}[1m])) by (status)",
            "legendFormat": "HTTP {{ status }}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": { "lineWidth": 1.5, "fillOpacity": 8 }
          }
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      }
    ]
  },
  "overwrite": true,
  "inputs": [],
  "folderId": 0
}
